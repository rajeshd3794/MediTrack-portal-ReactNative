{
  "info": {
    "name": "Meditrack Portal APIs (FastAPI 3-Tier)",
    "description": "Comprehensive Postman Core API Collection for the Python FastAPI Backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://meditrack-portal.loca.lt/api/v1",
      "type": "string"
    },
    {
      "key": "meditrack_api_key",
      "value": "YOUR_API_KEY_HERE",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Patients API",
      "item": [
        {
          "name": "Get All Patients",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{meditrack_api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/patients",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "patients"
              ]
            }
          }
        },
        {
          "name": "Get Patient by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{meditrack_api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/patients/testpatient",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "patients",
                "testpatient"
              ]
            }
          }
        },
        {
          "name": "Create Patient",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{meditrack_api_key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Test Patient\",\n    \"username\": \"testpatient\",\n    \"email\": \"test@example.com\",\n    \"dob\": \"01/01/1990\",\n    \"password\": \"v2_password\",\n    \"age\": 34,\n    \"condition\": \"Healthy\",\n    \"status\": \"Active\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/patients",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "patients"
              ]
            }
          }
        },
        {
          "name": "Update Patient",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{meditrack_api_key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"Discharged\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/patients/testpatient",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "patients",
                "testpatient"
              ]
            }
          }
        },
        {
          "name": "Delete Patient",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{meditrack_api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/patients/testpatient",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "patients",
                "testpatient"
              ]
            }
          }
        }
      ]
    },
